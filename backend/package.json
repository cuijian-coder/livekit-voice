{
  "name": "livekit-voice-backend",
  "version": "0.1.0",
  "description": "Realtime AI Voice Runtime",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "start": "node --import tsx src/main.ts",
    "build": "tsc",
    "test": "vitest",
    "test:run": "vitest run",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@livekit-voice/shared": "workspace:*",
    "fastify": "^5.2.1",
    "@fastify/websocket": "^11.0.1",
    "@fastify/cors": "^10.0.1",
    "ws": "^8.18.0",
    "xstate": "^5.18.2",
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0",
    "dotenv": "^16.4.7",
    "nanoid": "^5.0.9",
    "events": "^3.3.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.7",
    "@types/ws": "^8.5.13",
    "typescript": "^5.7.3",
    "tsx": "^4.19.2",
    "vitest": "^3.0.4",
    "eslint": "^9.18.0",
    "@eslint/js": "^9.18.0",
    "typescript-eslint": "^8.21.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}