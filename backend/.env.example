# Server Configuration
PORT=3000
HOST=0.0.0.0
NODE_ENV=development
LOG_LEVEL=info

# 通义千问 API
QWEN_API_KEY=your_api_key_here
QWEN_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1

# ASR 配置 (Fun-ASR Realtime)
ASR_MODEL=fun-asr-realtime
ASR_FORMAT=pcm
ASR_SAMPLE_RATE=16000

# LLM 配置
LLM_MODEL=qwen-turbo
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=2000

# TTS 配置模式: http (HTTP异步轮询) 或 websocket (WebSocket流式)
TTS_MODE=websocket

# NLS Gateway TTS 配置 (用于 TTS)
# appkey 和 token 需要从阿里云控制台获取
NLS_TTS_APPKEY=your_nls_appkey
NLS_TTS_TOKEN=your_nls_token
NLS_TTS_VOICE=xiaoyun
NLS_TTS_FORMAT=wav
NLS_TTS_SAMPLE_RATE=16000
NLS_TTS_WEBSOCKET_URL=wss://nls-gateway-cn-beijing.aliyuncs.com/ws/v1

# 心跳配置
HEARTBEAT_INTERVAL_MS=30000
HEARTBEAT_TIMEOUT_MS=60000